{% extends 'admin/_layout.html.twig' %}
{% block title %}Administration — Feedbacks utilisateurs{% endblock %}

{% block admin_body %}
<div class="mb-3">
    <h4 class="fw-bold mb-0"><i class="bi bi-chat-left-text text-primary me-2"></i>Feedbacks utilisateurs</h4>
</div>

{% if feedbacks is empty %}
    <div class="card border-0 shadow-sm p-4 text-center text-muted">
        <i class="bi bi-chat-left fs-2 mb-2"></i><br>
        Aucun feedback reçu pour le moment.
    </div>
{% else %}
<p class="text-muted small mb-2">{{ feedbacks|length }} message(s) — les nouveaux sont marqués comme lus à l'ouverture de cette page.</p>

<div class="d-flex flex-column gap-2">
{% for fb in feedbacks %}
    <div class="card border-0 shadow-sm {{ not fb.lu ? 'border-start border-primary border-3' : '' }}">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between gap-2"
             style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#fb{{ fb.id }}">
            <div class="d-flex align-items-center gap-2 flex-grow-1 min-w-0">
                {% if not fb.lu %}
                    <span class="badge bg-primary flex-shrink-0">Nouveau</span>
                {% endif %}
                <span class="fw-semibold small text-truncate">{{ fb.sujet }}</span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <span class="text-muted small font-monospace" style="font-size:11px;">
                    {{ fb.createdAt|date('d/m/Y H:i') }}
                </span>
                <span class="text-muted small">{{ fb.userLabel }}</span>
            </div>
        </div>
        <div class="collapse show" id="fb{{ fb.id }}">
            <div class="card-body py-3 px-3">
                <pre class="mb-0 small" style="white-space:pre-wrap;word-break:break-word;font-family:inherit;">{{ fb.contenu }}</pre>
            </div>
        </div>
    </div>
{% endfor %}
</div>
{% endif %}
{% endblock %}

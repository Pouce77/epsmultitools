<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ sujet }}</title>
    <style>
        body { margin: 0; padding: 0; background: #f4f6f8; font-family: Arial, Helvetica, sans-serif; color: #222; }
        .wrapper { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .header { background: #0f9e8e; padding: 28px 32px; }
        .header h1 { margin: 0; color: #fff; font-size: 22px; font-weight: 700; letter-spacing: -.3px; }
        .header p { margin: 4px 0 0; color: rgba(255,255,255,.8); font-size: 13px; }
        .body { padding: 32px; }
        .body p { margin: 0 0 16px; line-height: 1.6; font-size: 15px; }
        .greeting { font-size: 16px; font-weight: 600; margin-bottom: 20px; }
        .content { border-left: 3px solid #0f9e8e; padding-left: 16px; margin-bottom: 24px; }
        .footer { background: #f4f6f8; padding: 20px 32px; text-align: center; }
        .footer p { margin: 0; font-size: 12px; color: #888; line-height: 1.5; }
        .footer a { color: #0f9e8e; text-decoration: none; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="header">
            <h1><span style="opacity:.7;">⚡</span> EPS Multi-Tools</h1>
            <p>Message de l'équipe</p>
        </div>
        <div class="body">
            <p class="greeting">Bonjour {{ user.prenom }} 👋</p>
            <div class="content">
                {{ corps|raw }}
            </div>
            <p style="font-size:13px;color:#666;">
                Vous recevez cet email car vous êtes inscrit(e) sur EPS Multi-Tools.<br>
                Si vous ne souhaitez plus recevoir ces messages, contactez-nous.
            </p>
        </div>
        <div class="footer">
            <p>
                © {{ "now"|date("Y") }} EPS Multi-Tools &nbsp;·&nbsp;
                <a href="{{ app.request.schemeAndHttpHost }}">Accéder au site</a>
            </p>
            <p style="margin-top:8px;">
                <a href="{{ unsubscribeUrl }}" style="color:#aaa;font-size:11px;">Me désinscrire de la newsletter</a>
            </p>
        </div>
    </div>
</body>
</html>

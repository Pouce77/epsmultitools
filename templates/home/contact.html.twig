{% extends 'base.html.twig' %}
{% block title %}Contact — EPS Multi-Tools{% endblock %}

{% block body %}
<div class="container py-5" style="max-width:760px;">

    <h1 class="fw-bold mb-1">Nous contacter</h1>
    <p class="text-muted mb-5">Une question, un bug, une suggestion ? Retrouvez ci-dessous les moyens de nous joindre.</p>

    <div class="row g-4">

        {# ── Formulaire de contact ───────────────────────────── #}
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-4">
                        <i class="bi bi-envelope-fill me-2" style="color:#0f9e8e;"></i>Envoyer un message
                    </h2>

                    {% for msg in app.flashes('success') %}
                        <div class="alert alert-success d-flex gap-2 align-items-start">
                            <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
                            <div>{{ msg }}</div>
                        </div>
                    {% endfor %}

                    {% if error %}
                        <div class="alert alert-danger d-flex gap-2 align-items-start">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                            <div>{{ error }}</div>
                        </div>
                    {% endif %}

                    <form action="{{ path('app_contact') }}" method="post" novalidate>
                        <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">

                        <div class="mb-3">
                            <label for="contact-nom" class="form-label fw-semibold small">
                                Nom complet <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="contact-nom" name="nom"
                                   class="form-control"
                                   placeholder="Prénom Nom"
                                   value="{{ fields.nom }}"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="contact-email" class="form-label fw-semibold small">
                                Adresse e-mail <span class="text-danger">*</span>
                            </label>
                            <input type="email" id="contact-email" name="email"
                                   class="form-control"
                                   placeholder="votre@email.fr"
                                   value="{{ fields.email }}"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="contact-sujet" class="form-label fw-semibold small">
                                Sujet <span class="text-danger">*</span>
                            </label>
                            <select id="contact-sujet" name="sujet" class="form-select" required>
                                <option value="">— Choisir un sujet —</option>
                                {% set sujets = [
                                    'Question générale',
                                    'Signalement d\'un bug',
                                    'Suggestion d\'amélioration',
                                    'Problème de compte',
                                    'Autre',
                                ] %}
                                {% for s in sujets %}
                                    <option value="{{ s }}" {{ fields.sujet == s ? 'selected' : '' }}>{{ s }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="contact-message" class="form-label fw-semibold small">
                                Message <span class="text-danger">*</span>
                            </label>
                            <textarea id="contact-message" name="message"
                                      class="form-control" rows="5"
                                      placeholder="Décrivez votre demande…"
                                      required>{{ fields.message }}</textarea>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       id="contact-rgpd" name="rgpd" value="1" required>
                                <label class="form-check-label small text-muted" for="contact-rgpd">
                                    J'accepte que mes données soient utilisées pour répondre à ma demande
                                    (<a href="{{ path('app_confidentialite') }}">politique de confidentialité</a>).
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn fw-bold px-4" style="background:#0f9e8e;color:white;">
                            <i class="bi bi-send me-2"></i>Envoyer
                        </button>
                    </form>
                </div>
            </div>
        </div>

        {# ── Infos de contact ────────────────────────────────── #}
        <div class="col-lg-5 d-flex flex-column gap-3">

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">
                        <i class="bi bi-person-circle me-2" style="color:#0f9e8e;"></i>Coordonnées
                    </h2>
                    <ul class="list-unstyled text-muted small mb-0">
                        <li class="mb-2 d-flex align-items-start gap-2">
                            <i class="bi bi-envelope mt-1" style="color:#0f9e8e;flex-shrink:0;"></i>
                            <a href="mailto:julienkunze@jkwebcreation.fr">julienkunze@jkwebcreation.fr</a>
                        </li>
                        <li class="d-flex align-items-start gap-2">
                            <i class="bi bi-clock mt-1" style="color:#0f9e8e;flex-shrink:0;"></i>
                            <span>Réponse sous 48h en jours ouvrés</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-3">
                        <i class="bi bi-shield-lock me-2" style="color:#0f9e8e;"></i>Données & RGPD
                    </h2>
                    <p class="text-muted small mb-0">
                        Pour toute demande relative à vos données personnelles (accès, rectification, suppression),
                        contactez-nous à
                        <a href="mailto:julienkunze@jkwebcreation.fr">julienkunze@jkwebcreation.fr</a>
                        en précisant l'objet "Demande RGPD".
                    </p>
                </div>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}

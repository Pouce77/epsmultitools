{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe — EPS Multi-Tools{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 mt-3">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock-fill display-5" style="color:#0f9e8e;"></i>
                    <h2 class="fw-bold mt-2">Nouveau mot de passe</h2>
                </div>

                {% if invalid %}
                    <div class="alert alert-danger d-flex gap-2 align-items-start">
                        <i class="bi bi-x-circle-fill flex-shrink-0 mt-1"></i>
                        <div>
                            Ce lien est <strong>invalide ou expiré</strong> (validité : 1 heure).
                            <br>Veuillez effectuer une nouvelle demande.
                        </div>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_forgot_password') }}" class="btn btn-primary">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Nouvelle demande
                        </a>
                    </div>
                {% else %}
                    {% if error %}
                        <div class="alert alert-danger d-flex gap-2 align-items-start">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                            <div>{{ error }}</div>
                        </div>
                    {% endif %}

                    {# Indicateurs de force #}
                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <span id="ind-length"  class="badge rounded-pill" style="background:#6c757d;font-size:.78rem;">12 caractères min.</span>
                        <span id="ind-upper"   class="badge rounded-pill" style="background:#6c757d;font-size:.78rem;">1 majuscule</span>
                        <span id="ind-digit"   class="badge rounded-pill" style="background:#6c757d;font-size:.78rem;">1 chiffre</span>
                        <span id="ind-special" class="badge rounded-pill" style="background:#6c757d;font-size:.78rem;">1 caractère spécial</span>
                    </div>

                    <form method="post"
                          action="{{ path('app_reset_password', {token: token}) }}"
                          novalidate>
                        <input type="hidden" name="_token"
                               value="{{ csrf_token('reset_password_' ~ token) }}">

                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold">Nouveau mot de passe</label>
                            <div class="input-group">
                                <input type="password" id="password" name="password"
                                       class="form-control form-control-lg"
                                       placeholder="••••••••"
                                       autocomplete="new-password" autofocus required>
                                <button type="button" class="btn btn-outline-secondary" id="toggle-pwd1"
                                        tabindex="-1" aria-label="Afficher/masquer">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="password2" class="form-label fw-semibold">Confirmer le mot de passe</label>
                            <div class="input-group">
                                <input type="password" id="password2" name="password2"
                                       class="form-control form-control-lg"
                                       placeholder="••••••••"
                                       autocomplete="new-password" required>
                                <button type="button" class="btn btn-outline-secondary" id="toggle-pwd2"
                                        tabindex="-1" aria-label="Afficher/masquer">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-lg w-100 fw-semibold text-white"
                                style="background:#0f9e8e;">
                            <i class="bi bi-check-lg me-2"></i>Enregistrer le mot de passe
                        </button>
                    </form>

                    <script>
                    ;(function () {
                        const pwd  = document.getElementById('password')
                        const pwd2 = document.getElementById('password2')

                        function makeToggle(btnId, input) {
                            document.getElementById(btnId)?.addEventListener('click', function (e) {
                                e.preventDefault()
                                const show = input.getAttribute('type') === 'password'
                                input.setAttribute('type', show ? 'text' : 'password')
                                this.querySelector('i').className = show ? 'bi bi-eye-slash' : 'bi bi-eye'
                                input.focus()
                            })
                        }
                        makeToggle('toggle-pwd1', pwd)
                        makeToggle('toggle-pwd2', pwd2)

                        function setIndicator(id, ok) {
                            document.getElementById(id).style.background = ok ? '#198754' : '#6c757d'
                        }

                        pwd.addEventListener('input', function () {
                            const v = this.value
                            setIndicator('ind-length',  v.length >= 12)
                            setIndicator('ind-upper',   /[A-Z]/.test(v))
                            setIndicator('ind-digit',   /[0-9]/.test(v))
                            setIndicator('ind-special', /[\W_]/.test(v))
                        })
                    })()
                    </script>
                {% endif %}

            </div>
        </div>
    </div>
</div>
{% endblock %}

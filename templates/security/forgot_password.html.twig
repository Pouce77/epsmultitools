{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié — EPS Multi-Tools{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0 mt-3">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <i class="bi bi-key-fill display-5" style="color:#0f9e8e;"></i>
                    <h2 class="fw-bold mt-2">Mot de passe oublié</h2>
                    <p class="text-muted small">Saisissez votre adresse e-mail pour recevoir un lien de réinitialisation.</p>
                </div>

                {% if success %}
                    <div class="alert alert-success d-flex gap-2 align-items-start">
                        <i class="bi bi-envelope-check-fill flex-shrink-0 mt-1"></i>
                        <div>
                            Si un compte correspond à cette adresse, un e-mail de réinitialisation vient d'être envoyé.
                            <br><span class="text-muted" style="font-size:.85rem;">Pensez à vérifier vos spams.</span>
                        </div>
                    </div>
                    <div class="text-center mt-3">
                        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                        </a>
                    </div>
                {% else %}
                    {% if error %}
                        <div class="alert alert-danger d-flex gap-2 align-items-start">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                            <div>{{ error }}</div>
                        </div>
                    {% endif %}

                    <form method="post" action="{{ path('app_forgot_password') }}" novalidate>
                        <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">

                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold">Adresse e-mail</label>
                            <input type="email" id="email" name="email"
                                   class="form-control form-control-lg"
                                   placeholder="email@etablissement.fr"
                                   autocomplete="email" autofocus required>
                        </div>

                        <button type="submit" class="btn btn-lg w-100 fw-semibold text-white"
                                style="background:#0f9e8e;">
                            <i class="bi bi-send me-2"></i>Envoyer le lien
                        </button>
                    </form>

                    <hr>
                    <p class="text-center text-muted mb-0 small">
                        <a href="{{ path('app_login') }}">
                            <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                        </a>
                    </p>
                {% endif %}

            </div>
        </div>
    </div>
</div>
{% endblock %}

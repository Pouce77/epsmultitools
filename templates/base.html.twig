<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}EPS Multi-Tools{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}EPS Multi-Tools — Outils numériques gratuits pour enseignants d'EPS du second degré : compteur de vitesse, tableau de scores, tournoi, équipes équilibrées et plus.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">

    {# Open Graph #}
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:site_name" content="EPS Multi-Tools">
    <meta property="og:locale" content="fr_FR">
    <meta property="og:title" content="{% block og_title %}EPS Multi-Tools{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Outils numériques gratuits pour enseignants d'EPS : compteur de vitesse, scores, tournois, équipes équilibrées.{% endblock %}">
    <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost }}{{ asset('images/logo.png') }}">

    {# Twitter Card #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}EPS Multi-Tools{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}Outils numériques gratuits pour enseignants d'EPS.{% endblock %}">
    <meta name="twitter:image" content="{{ app.request.schemeAndHttpHost }}{{ asset('images/logo.png') }}">

    <link rel="icon" href="{{ asset('images/logo.png') }}">

    {# Bootstrap 5 — preconnect pour réduire la latence CDN #}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    {# defer : téléchargement parallèle au parsing, exécution après le DOM — garantit que
       Bootstrap est prêt avant toute interaction, même lors de la première visite (cache vide) #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>

    {% block stylesheets %}{% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body class="bg-light">

{% set _banner = global_banner() %}
{% if _banner %}
<div class="alert alert-{{ _banner.type }} alert-dismissible mb-0 rounded-0 border-0 text-center py-2" style="font-size:.9rem;">
    {{ _banner.contenu }}
    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm navbar-eps">
    <div class="container">
        <a class="navbar-brand fw-bold fs-5 d-flex align-items-center gap-2" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.png') }}" alt="EPS Multi-Tools" height="40">
            EPS Multi-Tools
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-grid-1x2-fill me-1"></i>Tableau de bord
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_resultat_index') }}">
                            <i class="bi bi-archive-fill me-1"></i>Résultats
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_classe_index') }}">
                            <i class="bi bi-people-fill me-1"></i>Mes classes
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>{{ app.user.prenom }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted small">{{ app.user.email }}</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_profile') }}">
                                    <i class="bi bi-person-gear me-1"></i>Mon compte
                                </a>
                            </li>
                            {% if is_granted('ROLE_ADMIN') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item fw-semibold" style="color:#e84020" href="{{ path('admin_dashboard') }}">
                                    <i class="bi bi-shield-fill me-1"></i>Administration
                                </a>
                            </li>
                            {% endif %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#modalFeedback">
                                    <i class="bi bi-chat-left-text me-1"></i>Donner un avis
                                </button>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning btn-sm fw-semibold ms-lg-2 px-3" href="{{ path('app_register') }}">
                            S'inscrire gratuitement
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="{% block main_class %}container py-4{% endblock %}">
    {% for type, messages in app.flashes(['success', 'danger', 'warning', 'info']) %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-{% if type == 'success' %}check-circle{% elseif type == 'danger' %}exclamation-triangle{% elseif type == 'warning' %}exclamation-circle{% else %}info-circle{% endif %}-fill me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="mt-auto py-4 bg-white border-top">
    <div class="container">
        <div class="row align-items-center g-3">
            <div class="col-md-4 text-center text-md-start">
                <img src="{{ asset('images/logo.png') }}" alt="" height="22" style="opacity:.85;" class="me-1">
                <strong class="text-dark">EPS Multi-Tools</strong>
                <div class="text-muted" style="font-size:.75rem;">Outils numériques pour les enseignants d'EPS</div>
            </div>
            <div class="col-md-4 text-center">
                <div class="d-flex justify-content-center gap-3 flex-wrap" style="font-size:.8rem;">
                    <a href="{{ path('app_mentions_legales') }}" class="text-muted text-decoration-none">Mentions légales</a>
                    <a href="{{ path('app_confidentialite') }}" class="text-muted text-decoration-none">Confidentialité</a>
                    <a href="{{ path('app_contact') }}" class="text-muted text-decoration-none">Contact</a>
                </div>
            </div>
            <div class="col-md-4 text-center text-md-end text-muted" style="font-size:.75rem;">
                © {{ "now"|date("Y") }} EPS Multi-Tools
            </div>
        </div>
    </div>
</footer>

{% block javascripts %}{% endblock %}

{% if app.user %}
<div class="modal fade" id="modalFeedback" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('feedback_submit') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('feedback') }}">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-chat-left-text me-2"></i>Donner un avis</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold" for="fb-sujet">Sujet <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="fb-sujet" name="sujet" maxlength="150" required placeholder="Résumé de votre retour">
                    </div>
                    <div class="mb-1">
                        <label class="form-label small fw-semibold" for="fb-contenu">Message <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="fb-contenu" name="contenu" rows="5" maxlength="5000" required placeholder="Décrivez votre retour, suggestion ou problème rencontré…"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-send me-1"></i>Envoyer</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}
</body>
</html>

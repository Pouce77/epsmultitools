<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}EPS Multi-Tools{% endblock %}</title>
    <link rel="icon" href="{{ asset('images/logo.png') }}">

    {# Bootstrap 5 — preconnect pour réduire la latence CDN #}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    {# defer : téléchargement parallèle au parsing, exécution après le DOM — garantit que
       Bootstrap est prêt avant toute interaction, même lors de la première visite (cache vide) #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>

    {% block stylesheets %}{% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm navbar-eps">
    <div class="container">
        <a class="navbar-brand fw-bold fs-5 d-flex align-items-center gap-2" href="{{ path('app_home') }}">
            <img src="{{ asset('images/logo.png') }}" alt="EPS Multi-Tools" height="40">
            EPS Multi-Tools
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_dashboard') }}">
                            <i class="bi bi-grid-1x2-fill me-1"></i>Tableau de bord
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_resultat_index') }}">
                            <i class="bi bi-archive-fill me-1"></i>Résultats
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_classe_index') }}">
                            <i class="bi bi-people-fill me-1"></i>Mes classes
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>{{ app.user.prenom }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted small">{{ app.user.email }}</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_profile') }}">
                                    <i class="bi bi-person-gear me-1"></i>Mon compte
                                </a>
                            </li>
                            {% if is_granted('ROLE_ADMIN') %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item fw-semibold" style="color:#e84020" href="{{ path('admin_dashboard') }}">
                                    <i class="bi bi-shield-fill me-1"></i>Administration
                                </a>
                            </li>
                            {% endif %}
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning btn-sm fw-semibold ms-lg-2 px-3" href="{{ path('app_register') }}">
                            S'inscrire gratuitement
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="{% block main_class %}container py-4{% endblock %}">
    {% for type, messages in app.flashes(['success', 'danger', 'warning', 'info']) %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-{% if type == 'success' %}check-circle{% elseif type == 'danger' %}exclamation-triangle{% elseif type == 'warning' %}exclamation-circle{% else %}info-circle{% endif %}-fill me-2"></i>
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="mt-auto py-4 bg-white border-top">
    <div class="container">
        <div class="row align-items-center g-3">
            <div class="col-md-4 text-center text-md-start">
                <img src="{{ asset('images/logo.png') }}" alt="" height="22" style="opacity:.85;" class="me-1">
                <strong class="text-dark">EPS Multi-Tools</strong>
                <div class="text-muted" style="font-size:.75rem;">Outils numériques pour les enseignants d'EPS</div>
            </div>
            <div class="col-md-4 text-center">
                <div class="d-flex justify-content-center gap-3 flex-wrap" style="font-size:.8rem;">
                    <a href="{{ path('app_mentions_legales') }}" class="text-muted text-decoration-none">Mentions légales</a>
                    <a href="{{ path('app_confidentialite') }}" class="text-muted text-decoration-none">Confidentialité</a>
                    <a href="{{ path('app_contact') }}" class="text-muted text-decoration-none">Contact</a>
                </div>
            </div>
            <div class="col-md-4 text-center text-md-end text-muted" style="font-size:.75rem;">
                © {{ "now"|date("Y") }} EPS Multi-Tools
            </div>
        </div>
    </div>
</footer>

{% block javascripts %}{% endblock %}
</body>
</html>

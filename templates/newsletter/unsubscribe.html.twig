{% extends 'base.html.twig' %}
{% block title %}Désinscription newsletter{% endblock %}

{% block body %}
<div class="container py-5" style="max-width:520px;">
    <div class="text-center mb-4">
        <a href="{{ path('app_home') }}" class="text-decoration-none">
            <span class="fw-bold fs-5 text-primary">⚡ EPS Multi-Tools</span>
        </a>
    </div>

    {% if success %}
        <div class="card border-0 shadow-sm text-center p-4">
            <div class="mb-3" style="font-size:3rem;">✅</div>
            <h5 class="fw-bold mb-2">Désinscription confirmée</h5>
            <p class="text-muted mb-4">
                Vous ne recevrez plus nos emails de newsletter.<br>
                Vous pouvez vous réinscrire à tout moment depuis votre profil.
            </p>
            <a href="{{ path('app_home') }}" class="btn btn-outline-primary btn-sm">Retour au site</a>
        </div>
    {% else %}
        <div class="card border-0 shadow-sm text-center p-4">
            <div class="mb-3" style="font-size:3rem;">❌</div>
            <h5 class="fw-bold mb-2">Lien invalide</h5>
            <p class="text-muted mb-4">
                Ce lien de désinscription est invalide ou a expiré.<br>
                Contactez-nous si vous souhaitez vous désinscrire.
            </p>
            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-sm">Retour au site</a>
        </div>
    {% endif %}
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Nouvelle classe — EPS Multi-Tools{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_classe_index') }}">Mes classes</a></li>
                <li class="breadcrumb-item active">Nouvelle classe</li>
            </ol>
        </nav>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-4"><i class="bi bi-plus-circle me-2 text-primary"></i>Nouvelle classe</h2>
                {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.niveau, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.niveau) }}
                    {{ form_errors(form.niveau) }}
                </div>
                <div class="mb-4">
                    {{ form_label(form.anneeScolaire, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.anneeScolaire) }}
                    {{ form_errors(form.anneeScolaire) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Créer la classe
                    </button>
                    <a href="{{ path('app_classe_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

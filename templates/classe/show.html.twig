{% extends 'base.html.twig' %}
{% block title %}{{ classe.nom }} — EPS Multi-Tools{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_classe_index') }}">Mes classes</a></li>
        <li class="breadcrumb-item active">{{ classe.nom }}</li>
    </ol>
</nav>

<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h1 class="fw-bold mb-1">{{ classe.nom }}</h1>
        <div class="d-flex gap-2 flex-wrap">
            {% if classe.niveau %}
                <span class="badge fs-6" style="background:#e6f7f5;color:#0a7468;border:1px solid #0f9e8e;">{{ classe.niveau }}</span>
            {% endif %}
            <span class="badge bg-light text-dark border fs-6">{{ classe.anneeScolaire }}</span>
            <span class="badge bg-secondary fs-6">{{ classe.effectif }} élève(s)</span>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('app_classe_edit', {id: classe.id}) }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i>Modifier
        </a>
        <a href="{{ path('app_eleve_new', {classeId: classe.id}) }}" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i>Ajouter un élève
        </a>
        <a href="{{ path('app_classe_import', {id: classe.id}) }}" class="btn btn-outline-success btn-sm">
            <i class="bi bi-upload me-1"></i>Importer
        </a>
    </div>
</div>

{# Tools #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
        <h5 class="fw-bold mb-0"><i class="bi bi-tools text-primary me-2"></i>Outils disponibles</h5>
    </div>
    <div class="card-body p-3">
        <div class="row g-2">
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_vitesse', {classeId: classe.id}) }}" class="btn btn-outline-primary w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">⏱️</span>
                    <small class="mt-1 fw-semibold">Vitesse</small>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_scores', {classeId: classe.id}) }}" class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">🏆</span>
                    <small class="mt-1 fw-semibold">Scores</small>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_actions', {classeId: classe.id}) }}" class="btn btn-outline-info w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">📊</span>
                    <small class="mt-1 fw-semibold">Actions</small>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_tournoi', {classeId: classe.id}) }}" class="btn btn-outline-danger w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">🎯</span>
                    <small class="mt-1 fw-semibold">Tournoi</small>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_equipes', {classeId: classe.id}) }}" class="btn btn-outline-success w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">⚖️</span>
                    <small class="mt-1 fw-semibold">Équipes</small>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
                <a href="{{ path('app_outil_impacts', {classeId: classe.id}) }}" class="btn btn-outline-danger w-100 h-100 d-flex flex-column align-items-center py-3">
                    <span class="fs-3">🎾</span>
                    <small class="mt-1 fw-semibold">Impacts</small>
                </a>
            </div>
        </div>
    </div>
</div>

{# Student list #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3 pb-0 px-4 d-flex align-items-center justify-content-between">
        <h5 class="fw-bold mb-0"><i class="bi bi-people text-primary me-2"></i>Liste des élèves</h5>
        <span class="badge bg-secondary">{{ classe.effectif }}</span>
    </div>
    <div class="card-body p-0">
        {% if classe.eleves is empty %}
        <div class="text-center py-5 text-muted">
            <div class="fs-1 mb-2">👤</div>
            <p>Aucun élève dans cette classe.</p>
            <a href="{{ path('app_eleve_new', {classeId: classe.id}) }}" class="btn btn-primary btn-sm me-2">
                <i class="bi bi-person-plus me-1"></i>Ajouter
            </a>
            <a href="{{ path('app_classe_import', {id: classe.id}) }}" class="btn btn-outline-success btn-sm">
                <i class="bi bi-upload me-1"></i>Importer
            </a>
        </div>
        {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th class="text-center">Sexe</th>
                        <th class="text-center">Niveau</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for i, eleve in classe.eleves %}
                    <tr>
                        <td class="text-muted small">{{ i + 1 }}</td>
                        <td class="fw-semibold">{{ eleve.nom }}</td>
                        <td>{{ eleve.prenom }}</td>
                        <td class="text-center">
                            {% if eleve.sexe == 'M' %}
                                <span class="badge bg-info bg-opacity-10 text-info border border-info">♂ M</span>
                            {% elseif eleve.sexe == 'F' %}
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger">♀ F</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">{{ eleve.niveau ?? 3 }}</span>
                        </td>
                        <td class="text-end pe-3">
                            <a href="{{ path('app_eleve_edit', {classeId: classe.id, id: eleve.id}) }}" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#deleteEleve{{ eleve.id }}">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>
</div>

{# Delete eleve modals #}
{% for eleve in classe.eleves %}
<div class="modal fade" id="deleteEleve{{ eleve.id }}" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Supprimer l'élève</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Supprimer <strong>{{ eleve.fullName }}</strong> ?
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="post" action="{{ path('app_eleve_delete', {classeId: classe.id, id: eleve.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-eleve-' ~ eleve.id) }}">
                    <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}

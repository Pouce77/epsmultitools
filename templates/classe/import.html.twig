{% extends 'base.html.twig' %}
{% block title %}Importer des élèves — {{ classe.nom }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_classe_index') }}">Mes classes</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_classe_show', {id: classe.id}) }}">{{ classe.nom }}</a></li>
                <li class="breadcrumb-item active">Importer</li>
            </ol>
        </nav>

        <h2 class="fw-bold mb-4"><i class="bi bi-upload me-2 text-success"></i>Importer des élèves dans {{ classe.nom }}</h2>

        {% if preview is not null %}
        {# Preview step #}
        <div class="card border-success shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Aperçu — {{ preview|length }} élève(s) à importer</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr><th>#</th><th>Nom</th><th>Prénom</th><th>Sexe</th></tr>
                        </thead>
                        <tbody>
                        {% for i, eleve in preview %}
                            <tr>
                                <td class="text-muted">{{ i + 1 }}</td>
                                <td class="fw-semibold">{{ eleve.nom }}</td>
                                <td>{{ eleve.prenom }}</td>
                                <td>
                                    {% if eleve.sexe == 'M' %}<span class="badge bg-info text-white">M</span>
                                    {% elseif eleve.sexe == 'F' %}<span class="badge bg-danger">F</span>
                                    {% else %}<span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <form method="post" action="{{ path('app_classe_import', {id: classe.id}) }}">
            <input type="hidden" name="confirm" value="1">
            {{ form_widget(form) }}
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i>Confirmer l'import ({{ preview|length }} élèves)
                </button>
                <a href="{{ path('app_classe_import', {id: classe.id}) }}" class="btn btn-outline-secondary">Modifier</a>
            </div>
        </form>

        {% else %}
        {# Input form #}
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="alert alert-info border-0 mb-4">
                    <i class="bi bi-lightbulb-fill me-2"></i>
                    <strong>Astuce :</strong> Copiez-collez votre liste depuis un fichier Excel, Word ou Pronote.
                    Accepte : <code>NOM Prénom</code>, <code>NOM;Prénom</code>, <code>NOM,Prénom,M</code>
                </div>

                {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.contenu, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.contenu) }}
                    {{ form_errors(form.contenu) }}
                </div>
                <div class="mb-4">
                    {{ form_label(form.format, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.format) }}
                    {{ form_errors(form.format) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-search me-1"></i>Prévisualiser
                    </button>
                    <a href="{{ path('app_classe_show', {id: classe.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

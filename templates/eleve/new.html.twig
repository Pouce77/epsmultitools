{% extends 'base.html.twig' %}
{% block title %}Ajouter un élève — {{ classe.nom }}{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_classe_show', {id: classe.id}) }}">{{ classe.nom }}</a></li>
                <li class="breadcrumb-item active">Ajouter un élève</li>
            </ol>
        </nav>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-4"><i class="bi bi-person-plus me-2 text-primary"></i>Nouvel élève</h2>
                {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.nom) }}
                        {{ form_errors(form.nom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.prenom) }}
                        {{ form_errors(form.prenom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.sexe, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.sexe) }}
                        {{ form_errors(form.sexe) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.dateNaissance, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.dateNaissance) }}
                        {{ form_errors(form.dateNaissance) }}
                    </div>
                </div>
                <div class="mt-3">
                    {{ form_label(form.niveau, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.niveau) }}
                    {{ form_errors(form.niveau) }}
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Ajouter
                    </button>
                    <a href="{{ path('app_classe_show', {id: classe.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

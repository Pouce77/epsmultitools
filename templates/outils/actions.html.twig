{% extends 'outils/_layout.html.twig' %}
{% block title %}Compteur d'actions — {{ classe.nom }}{% endblock %}
{% block tool_title %}📊 Compteur d'actions{% endblock %}

{% block tool_body %}
<div data-controller="actions"
     data-actions-eleves-value="{{ elevesJson }}"
     data-actions-classe-id-value="{{ classe.id }}">

    {# ── Tablet overlay ─────────────────────────────────────────────── #}
    <div data-actions-target="tabletOverlay"
         style="display:none; position:fixed; inset:0; z-index:1050; background:#0f172a; flex-direction:column;">

        {# Top bar #}
        <div class="d-flex align-items-center px-4 py-3" style="border-bottom:1px solid rgba(255,255,255,.12)">
            <button class="btn btn-outline-light btn-sm me-3" data-action="actions#closeTablet">
                <i class="bi bi-arrow-left me-1"></i>Liste
            </button>
            <div class="flex-grow-1 text-center">
                <div class="fw-bold text-white fs-4" data-actions-target="tabletStudentName">—</div>
                <div class="small" style="color:#94a3b8" data-actions-target="tabletStudentCounter">—</div>
            </div>
            <div style="width:80px"></div>{# spacer #}
        </div>

        {# Action counters #}
        <div class="flex-grow-1 overflow-auto d-flex align-items-center justify-content-center px-4 py-4">
            <div class="w-100" style="max-width:640px">
                <div data-actions-target="tabletActionButtons"></div>
                <div class="text-center mt-3" style="color:#94a3b8">
                    Total :
                    <span class="fw-bold text-white fs-3 ms-1" data-actions-target="tabletTotal">0</span>
                </div>
            </div>
        </div>

        {# Navigation #}
        <div class="d-flex gap-3 px-4 pb-5 pt-2">
            <button class="btn btn-outline-light flex-fill py-3"
                    style="font-size:1.1rem" data-action="actions#tabletPrev">
                <i class="bi bi-chevron-left me-2"></i>Précédent
            </button>
            <button class="btn btn-outline-light flex-fill py-3"
                    style="font-size:1.1rem" data-action="actions#tabletNext">
                Suivant<i class="bi bi-chevron-right ms-2"></i>
            </button>
        </div>
    </div>

    {# ── Action type config ─────────────────────────────────────────── #}
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="fw-semibold small">Types d'actions :</span>
                <div class="d-flex gap-2 flex-wrap" data-actions-target="labelContainer">
                    {# Labels filled by Stimulus #}
                </div>
                <button class="btn btn-sm btn-outline-primary" data-action="actions#addActionType">
                    <i class="bi bi-plus"></i> Ajouter
                </button>
                <div class="ms-auto d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-primary"
                            data-action="actions#toggleTablet"
                            data-actions-target="tabletToggleBtn">
                        <i class="bi bi-tablet me-1"></i>Mode tablette
                    </button>
                    <button class="btn btn-sm btn-success" data-action="actions#saveResults"
                            data-actions-target="saveBtn">
                        <i class="bi bi-cloud-upload-fill me-1"></i>Sauvegarder
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" data-action="actions#exportResults">
                        <i class="bi bi-clipboard me-1"></i>Copier résultats
                    </button>
                    <button class="btn btn-sm btn-outline-danger" data-action="actions#resetAll">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ── Main table ─────────────────────────────────────────────────── #}
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" id="actionsTable">
                <thead class="table-light" data-actions-target="tableHead">
                    {# Filled by Stimulus #}
                </thead>
                <tbody data-actions-target="tableBody">
                    {# Filled by Stimulus #}
                </tbody>
            </table>
        </div>
    </div>

    {# ── Export area ────────────────────────────────────────────────── #}
    <div class="mt-3 d-none" data-actions-target="exportArea">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <label class="form-label fw-semibold">Résultats (copiez-collez dans Excel)</label>
                <textarea class="form-control font-monospace" rows="10" data-actions-target="exportText" readonly></textarea>
            </div>
        </div>
    </div>
</div>
{% endblock %}
